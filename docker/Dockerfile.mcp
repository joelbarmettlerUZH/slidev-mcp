# Stage 1: Clone Slidev docs at pinned ref
FROM alpine/git:latest AS vendor
ARG SLIDEV_REF=v52.14.1
RUN git clone --depth 1 --branch ${SLIDEV_REF} --filter=blob:none --sparse \
    https://github.com/slidevjs/slidev.git /slidev && \
    cd /slidev && git sparse-checkout set docs/

# Stage 2: Python runtime
FROM python:3.13-slim

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

# Install dependencies first (cache layer)
COPY pyproject.toml uv.lock README.md ./
RUN uv sync --frozen --no-dev --no-install-project

# Copy vendored docs from stage 1
COPY --from=vendor /slidev/docs/ /app/vendor/slidev-docs/docs/

# Copy source and scripts
COPY src/ src/
COPY builder/themes.json /tmp/themes.json
COPY scripts/fetch-theme-readmes.py /tmp/fetch-theme-readmes.py

# Fetch theme READMEs from npm at build time
RUN python3 /tmp/fetch-theme-readmes.py /tmp/themes.json /app/src/slidev_mcp/resources/themes \
    && rm /tmp/themes.json /tmp/fetch-theme-readmes.py

# Create non-root user
RUN useradd --create-home --uid 1000 mcp
RUN chown -R mcp:mcp /app

CMD ["uv", "run", "--no-dev", "python", "-m", "slidev_mcp.server"]
