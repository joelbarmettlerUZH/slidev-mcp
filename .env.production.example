# Slidev MCP — Production Environment Variables
# Copy to .env.production and fill in values.
# NEVER commit .env.production to git.

# PostgreSQL
POSTGRES_PASSWORD=change-me-to-a-strong-random-password
DATABASE_URL=postgresql+asyncpg://slidev:${POSTGRES_PASSWORD}@postgres:5432/slidev

# Public domain (Traefik routes traffic here)
DOMAIN=mcp.slidev-mcp.org

# Server
SERVER_TRANSPORT=streamable-http
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
BUILDER_HOST=builder
BUILDER_PORT=3000

# Docker images (set by CI/CD, override for manual deploy)
GITHUB_REPOSITORY=joelbarmettlerUZH/slidev-mcp
IMAGE_TAG=latest

# Traefik / Let's Encrypt
ACME_EMAIL=you@example.com
